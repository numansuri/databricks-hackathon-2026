VITE_GOOGLE_MAPS_API_KEY=your_google_maps_javascript_api_key
# Optional: use a production Google Maps Map ID instead of the demo fallback.
VITE_GOOGLE_MAP_ID=your_google_maps_map_id

# --- Outreach agent (server-side only; NEVER prefix these with VITE_) ---
# Provider: "databricks" (in-network FM API; works in the deployed Free Edition app),
# "openai" (api.openai.com; needs egress + credits), or leave unset to auto-detect.
# LLM_PROVIDER=databricks
# Model / serving-endpoint name. Defaults: databricks-llama-4-maverick (databricks) or gpt-4.1-mini (openai).
# In-network model notes (this Free Edition workspace, empirically verified, 3x/model):
#   - databricks-llama-4-maverick: DEFAULT. Enabled, fast (~1.7s), non-reasoning,
#     reliably returns clean tailored JSON (3/3 success).
#   - databricks-gpt-oss-120b: OpenAI's open model, also enabled, BUT a reasoning model
#     that's unreliable for strict-JSON drafting here (3/3 fail) — it spends its token
#     budget reasoning and truncates the final JSON at max_tokens=1500. Not the default;
#     use only with a much larger max_tokens.
#   - databricks-gemini-3-5-flash / databricks-claude-opus-4-8: GATED (disabled) here.
# OUTREACH_MODEL=databricks-llama-4-maverick
# OpenAI direct (local dev or egress-enabled tiers):
# OPENAI_API_KEY=your_openai_api_key
# Databricks local dev (a PAT short-circuits the in-app OAuth flow):
# DATABRICKS_HOST=https://dbc-xxxx.cloud.databricks.com
# DATABRICKS_TOKEN=your_databricks_personal_access_token
